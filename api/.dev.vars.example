# .dev.vars template
# Copy this file to .dev.vars and fill in the values

# JWT Secret - Use a strong random string
JWT_SECRET=your-super-secret-key-change-this-in-production

# Web app URL. Its origin is also used for CORS.
APP_URL=http://localhost:5173

# App name used in outbound emails.
APP_NAME=Virtue Initiative

# Optional path prefix that the worker should also accept.
# Example: /api makes both https://api.example.com/login and https://example.com/api/login work.
API_BASE_PATH=/api

# Public base URL for R2 batch blobs
R2_URL=http://localhost:8787/r2

# Hash API base URL used by /d/batch server-side hash state calls.
# For local dev this must be server-reachable, not emulator alias hostnames.
HASH_SERVER_URL=http://127.0.0.1:8787

# Can be changed to SES
EMAIL_DELIVERY_MODE=log

# AWS credentials for SES
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
