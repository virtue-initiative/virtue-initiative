# .dev.vars template
# Copy this file to .dev.vars and fill in the values

# JWT Secret - Use a strong random string
JWT_SECRET=your-super-secret-key-change-this-in-production

# Allowed CORS origin (web app URL)
CORS_ORIGIN=http://localhost:5173

# Public base URL for R2 batch blobs
R2_URL=http://localhost:8787/r2

# Hash API base URL used by /d/batch server-side hash state calls.
# For local dev this must be server-reachable, not emulator alias hostnames.
HASH_SERVER_URL=http://127.0.0.1:8787
