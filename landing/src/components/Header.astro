---
import { APP_URL } from "../lib/app-url";

interface Props {
  tagline?: string;
}

const { tagline } = Astro.props;
---

<header>
  <div class="container">
    <div class="header-top">
      <div class="header-copy">
        <a href="/" class="wordmark">The Virtue Initiative</a>
        {tagline && <p class="tagline">{tagline}</p>}
      </div>
      <div class="header-actions">
        <button
          class="control control-icon"
          id="theme-toggle"
          aria-label="Toggle dark mode"></button>
        <a href={APP_URL} class="btn btn-primary">
          Login / Sign up
        </a>
      </div>
    </div>
  </div>
</header>
