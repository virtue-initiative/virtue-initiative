---
import type { MarkdownInstance } from "astro";
import HelpLayout from "../../layouts/HelpLayout.astro";
import { findHelpItem } from "../../help/navigation";

export function getStaticPaths() {
  return Object.entries(
    import.meta.glob<MarkdownInstance<Record<string, never>>>(
      "../../content/help/**/*.md",
      { eager: true },
    ),
  ).map(([key, module]) => {
    const routePath = key
      .replace("../../content/help/", "")
      .replace(/\.md$/, "")
      .replace(/\/index$/, "");

    return {
      params: {
        slug: routePath,
      },
      props: {
        currentPath: `/help/${routePath}`,
        entry: module,
      },
    };
  });
}

const APP_URL = import.meta.env.PUBLIC_APP_URL || "http://localhost:5173";
const SIGNUP_URL = `${APP_URL}#signup`;
const { currentPath, entry } = Astro.props;
const currentItem = findHelpItem(currentPath);
const contentHtml = (await entry.compiledContent())
  .replaceAll('href="/app"', `href="${APP_URL}"`)
  .replaceAll('href="/signup"', `href="${SIGNUP_URL}"`);
---

<HelpLayout currentPath={currentPath} pageTitle={currentItem?.label ?? "Help"}>
  <article class="help-content-card help-doc" set:html={contentHtml} />
</HelpLayout>
