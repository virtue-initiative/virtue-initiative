---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ThemeHeadScript from "../components/ThemeHeadScript.astro";
import ThemeScript from "../components/ThemeScript.astro";
import { helpSidebar } from "../help/navigation";
import "../styles/global.css";

interface Props {
  currentPath: string;
  pageTitle?: string;
}

const { currentPath, pageTitle = "Help" } = Astro.props;
const title = `${pageTitle} - The Virtue Initiative`;
const rootLinks = [{ label: "Help", href: "/help" }, ...helpSidebar];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <ThemeHeadScript />
    <title>{title}</title>
  </head>
  <body class="help-page">
    <Header tagline="Guides and docs for The Virtue Initiative" />
    <main class="help-main">
      <aside class="help-sidebar">
        <ul class="help-sidebar-list">
          {
            rootLinks.map((item) => (
              <li>
                {item.href && (
                  <a
                    href={item.href}
                    class:list={[
                      "help-sidebar-item",
                      { active: item.href === currentPath },
                    ]}
                  >
                    {item.label}
                  </a>
                )}
                {item.items && item.items.length > 0 && (
                  <ul class="help-sidebar-sublist">
                    {item.items.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            "help-sidebar-item",
                            "help-sidebar-item-child",
                            { active: child.href === currentPath },
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))
          }
        </ul>
      </aside>

      <div class="help-content">
        <slot />
      </div>
    </main>
    <Footer />
    <ThemeScript />
  </body>
</html>
